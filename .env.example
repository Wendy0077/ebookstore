# MongoDB (ใช้ Atlas: mongodb+srv://user:password@cluster.mongodb.net/dbname)
MONGODB_URI=

# JWT (random string ยาวๆ เช่น: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-secret-string

# Google OAuth (จาก console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (จาก dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# S3 / Object Storage (จำเป็นสำหรับอัปโหลดไฟล์บน Vercel)
S3_REGION=ap-southeast-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Cron secret (random string ใช้ป้องกัน /api/cron/* — openssl rand -hex 32)
CRON_SECRET=